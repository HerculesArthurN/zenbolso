{
  "version": "1.0",
  "mode": "yolo",
  "granularity": "coarse",
  "parallelization": {
    "enabled": true
  },
  "planning": {
    "commit_docs": true
  },
  "model_profile": "inherit",
  "workflow": {
    "research": false,
